# Скопируй в .env и заполни. Файл .env в git не попадает (см. .gitignore).

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram user ID (узнать у @userinfobot). Бот отвечает только этому ID.
ALLOWED_USER_ID=000000000

# (необязательно) Корень, по которому искать _state.md и запускать оркестр.
# По умолчанию — рабочая папка Ai-homework (на уровень выше launch-pult).
# WORKSPACE_ROOT=/Users/olgakhaidukova/Desktop/Ai-homework

# (необязательно) Путь к исполняемому claude, если он не в PATH.
# CLAUDE_BIN=claude

# (необязательно) Таймаут ответа оркестра в секундах.
# ORCHESTRA_TIMEOUT=180

# (необязательно) Какие инструменты разрешены оркестру при ответе.
# По умолчанию "Write Edit" — бот может создавать и править файлы, но НЕ удалять
# (Bash в список не входит → rm недоступен). Поставь пусто для режима read-only.
# ORCHESTRA_ALLOWED_TOOLS=Write Edit

# (нужно для «🎬 ТЗ на монтаж», если источник — Kinescope ID/ссылка)
# Токен Kinescope API: montage_tz.py по нему скачивает запись.
# Локальный путь к видео токена не требует.
# KINESCOPE_API_TOKEN=...
