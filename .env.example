# Скопируй в .env и заполни. Файл .env в git не попадает (см. .gitignore).

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram user ID (узнать у @userinfobot) — ВЛАДЕЛЕЦ, полный доступ.
ALLOWED_USER_ID=000000000

# (необязательно) Открытый доступ. По умолчанию (1) бот доступен ВСЕМ по ссылке —
# никаких списков ID и кодов: дал ссылку, коллега зашёл и пользуется. Все запросы
# идут через общий ANTHROPIC_API_KEY (ниже), не через подписку владельца.
# Поставь 0, чтобы запереть бота на владельца + список гостей (GUEST_USER_IDS).
# OPEN_ACCESS=1

# (необязательно, работает только при OPEN_ACCESS=0) Гости — коллеги команды.
# Список Telegram ID через запятую. Полный доступ ко всем функциям.
# GUEST_USER_IDS=111111111,222222222

# (необязательно, но нужно для «общего бота») Общий API-ключ Anthropic.
# Если задан — ВСЕ ИИ-запросы бота (свои и гостей) идут через него и оплачиваются
# с него, а НЕ с подписки-логина владельца на хосте. Так бот не привязан к личным
# токенам: ставишь сюда ключ компании (или тестовый) — платит он.
# Если пусто — бот работает на подписке Claude Code того, кто залогинен на хосте.
# Получить: console.anthropic.com → API Keys → Create Key.
# ANTHROPIC_API_KEY=sk-ant-...

# (необязательно) Корень, по которому искать _state.md и запускать оркестр.
# По умолчанию — рабочая папка Ai-homework (на уровень выше launch-pult).
# WORKSPACE_ROOT=/Users/olgakhaidukova/Desktop/Ai-homework

# (необязательно) Путь к исполняемому claude, если он не в PATH.
# CLAUDE_BIN=claude

# (необязательно) Таймаут ответа оркестра в секундах.
# ORCHESTRA_TIMEOUT=180

# (необязательно) Какие инструменты разрешены оркестру при ответе.
# По умолчанию "Write Edit" — бот может создавать и править файлы, но НЕ удалять
# (Bash в список не входит → rm недоступен). Поставь пусто для режима read-only.
# ORCHESTRA_ALLOWED_TOOLS=Write Edit

# (нужно для «🎬 ТЗ на монтаж», если источник — Kinescope ID/ссылка)
# Токен Kinescope API: montage_tz.py по нему скачивает запись.
# Локальный путь к видео токена не требует.
# KINESCOPE_API_TOKEN=...

# (необязательно) Авто-выгрузка готовых черновиков на Google Диск как Google Doc.
# Доступ — пользовательский OAuth («вход как владелец»): файлы на ЕГО Диске, его
# квота → работает на личном Gmail (сервис-аккаунт там упирается в storageQuotaExceeded).
# Если token-файл задан — бот после .docx в чат кладёт док на Диск и дописывает ссылку.
# Пусто — просто шлёт .docx, как сейчас. Настройка: docs/google-drive-setup.md.
# GOOGLE_OAUTH_TOKEN_FILE=/opt/pult-bot/launch-pult/secrets/token.json
# GOOGLE_DRIVE_FOLDER_ID=...   # id папки на Диске; пусто = «Мой диск»
